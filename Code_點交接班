<div>(function findByTextAndClick(doc = document) {</div><div>&nbsp; &nbsp; const targetText = "住院醫師接班"; // 設定目標文字</div><div>&nbsp; &nbsp;&nbsp;</div><div>&nbsp; &nbsp; // 1. 在當前 document 找尋所有包含此文字的 span 或 td</div><div>&nbsp; &nbsp; const elements = doc.querySelectorAll('span, td, a, tr');</div><div>&nbsp; &nbsp; for (let el of elements) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; // 檢查文字是否完全匹配，且該元素是可點擊的 (或是其父層 tr)</div><div>&nbsp; &nbsp; &nbsp; &nbsp; if (el.innerText.trim() === targetText || el.textContent.includes(targetText)) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; console.log("%c 找到目標文字：" + targetText, "color: #D1FB83; background: #003300;");</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;&nbsp;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; // 優先嘗試點擊它所屬的 TR (因為 onclick 通常掛在 tr 上)</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; const parentTR = el.closest('tr');</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; if (parentTR) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; parentTR.click();</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; } else {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; el.click();</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; return true;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; }</div><div><br></div><div>&nbsp; &nbsp; // 2. 遞迴搜尋所有框架</div><div>&nbsp; &nbsp; const frames = doc.querySelectorAll('frame, iframe');</div><div>&nbsp; &nbsp; for (let i = 0; i &lt; frames.length; i++) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; try {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; const frameDoc = frames[i].contentDocument || frames[i].contentWindow.document;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; if (findByTextAndClick(frameDoc)) return true;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; } catch (e) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; // 跳過跨網域限制</div><div>&nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; }</div><div>&nbsp; &nbsp;&nbsp;</div><div>&nbsp; &nbsp; if (doc === document) console.error("找不到文字為「" + targetText + "」的元素");</div><div>&nbsp; &nbsp; return false;</div><div>})();</div>