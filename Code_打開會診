bsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; return true;&nbsp;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; }</div><div><br></div><div>&nbsp; &nbsp; &nbsp; &nbsp; // C. 如果這層沒找到，往子層 iframe 鑽</div><div>&nbsp; &nbsp; &nbsp; &nbsp; const iframes = doc.querySelectorAll('iframe, frame');</div><div>&nbsp; &nbsp; &nbsp; &nbsp; for (let frame of iframes) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; try {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; const frameDoc = frame.contentDocument || frame.contentWindow.document;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; if (findAndAct(frameDoc)) return true;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; } catch (e) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; // 跨網域 iframe 跳過</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; return false;</div><div>&nbsp; &nbsp; }</div><div><br></div><div>&nbsp; &nbsp; // 3. 填表與查詢邏輯</div><div>&nbsp; &nbsp; function fillForm(doc) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; // 因為點擊選單後可能在另一個 iframe 出現欄位，再次全域搜尋</div><div>&nbsp; &nbsp; &nbsp; &nbsp; const targetDocs = [document, ...Array.from(document.querySelectorAll('iframe, frame')).map(f =&gt; {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; try { return f.contentDocument || f.contentWindow.document; } catch(e) { return null; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; }).filter(d =&gt; d)];</div><div><br></div><div>&nbsp; &nbsp; &nbsp; &nbsp; targetDocs.forEach(d =&gt; {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; const dateInput = d.querySelector('#MinAccDate');</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; const costInput = d.querySelector('#ConsultCostNo');</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; const queryBtn = d.querySelector('#QueryBtn');</div><div><br></div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; if (dateInput) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; dateInput.value = dateStr;</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; dateInput.onblur &amp;&amp; dateInput.onblur(); // 觸發網頁驗證</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; if (costInput) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; costInput.value = 'AP100';</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; costInput.onchange &amp;&amp; costInput.onchange();</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; if (queryBtn) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; console.log("正在點擊查詢按鈕...");</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; queryBtn.click();</div><div>&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; }</div><div>&nbsp; &nbsp; &nbsp; &nbsp; });</div><div>&nbsp; &nbsp; }</div><div><br></div><div>&nbsp; &nbsp; // 執行啟動</div><div>&nbsp; &nbsp; if (!findAndAct(document)) {</div><div>&nbsp; &nbsp; &nbsp; &nbsp; console.error("找不到「-會診作業」，請確認選單文字是否完全一致。");</div><div>&nbsp; &nbsp; }</div><div>})();</div>